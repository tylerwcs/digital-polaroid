# Media
public/*.mov
public/*.mp4
# Wall background videos referenced by DisplayView — allow these despite public/*.mp4 above
!public/BG.mp4
# Bubble-theme variant background video (see docs/BUBBLE_VARIANT.md)
!public/bubbleBG.mp4

# Runtime-uploaded photos (already-tracked sample uploads stay tracked; new ones are ignored)
server/uploads/*
!server/uploads/.gitkeep

